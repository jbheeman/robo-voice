{
  "expo": {
    "name": "BELT Campus Guide",
    "slug": "belt-campus-guide",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bianca.beltcampusguide",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "BELT connects to the development server running on your Mac."
      }
    },
    "android": {
      "package": "com.bianca.beltcampusguide"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow BELT to use the camera to understand your surroundings.",
          "microphonePermission": "Allow BELT to use the microphone.",
          "recordAudioAndroid": true,
          "barcodeScannerEnabled": false
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow BELT to listen when you press the talk button.",
          "enableBackgroundPlayback": false,
          "enableBackgroundRecording": false
        }
      ],
      "expo-asset",
      "expo-status-bar"
    ]
  }
}
